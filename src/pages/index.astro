---
// Componit Imports
import Card from "../components/Card.astro";
import MainLayout from "../layouts/MainLayout.astro";
import "../styles/bg-img.css";

import data from "../data/feature.json";
---

<MainLayout title="Home">
    <img
        src="/images/GuildLogoVector.png "
        style="display: block; margin-left: auto; margin-right: auto; margin-top: 5dvh; width: 35vw; filter: invert(99%) sepia(65%) saturate(1836%) hue-rotate(328deg) brightness(107%) contrast(97%);"
        alt="Guild Logo"
    />

    <!-- <div class="flex flex-wrap justify-center my-5">
        {data.map((card) => <Card data={card} />)}
    </div> -->

    <div id="default-carousel" class="relative w-[80dvw}" data-carousel="slide">
        <div class="relative h-56 overflow-hidden rounded-base md:h-96">
            {data.map((card) => <Card data={card} />)}
        </div>
    </div>

</MainLayout>
